# Copy to .env.local and fill in. Local file is gitignored.
# For deployed envs (Coolify), set these in the Coolify env panel.

# ===== REQUIRED =====

# Postgres on M90t — same string as ~/evergreen-core/.env.local
DATABASE_URL=

# Better Auth secret — same value as EC's BETTER_AUTH_SECRET. This is what
# makes shared sessions work; if it differs, LifeOS can't validate EC's cookies.
BETTER_AUTH_SECRET=

# Local dev: http://localhost:3001
# Production:  https://lifeos.evergreenwellnessmktg.com
NEXT_PUBLIC_APP_URL=http://localhost:3001

# EC's URL — used as a trusted origin and for the redirect-to-sign-in fallback.
# Local dev:  http://localhost:3000
# Production: https://app.evergreenwellnessmktg.com
NEXT_PUBLIC_EC_URL=https://app.evergreenwellnessmktg.com

# ===== PRODUCTION-ONLY =====

# Set this on Coolify to enable cross-subdomain cookies between
# app.evergreenwellnessmktg.com and lifeos.evergreenwellnessmktg.com.
# Leave UNSET for local dev (cross-port localhost cookies don't need it).
# EC must have the same value set on its prod env.
# BETTER_AUTH_COOKIE_DOMAIN=.evergreenwellnessmktg.com

# Comma-separated list of additional trusted origins for Better Auth.
# Useful when an extra deploy preview URL needs to validate sessions.
# BETTER_AUTH_TRUSTED_ORIGINS=https://lifeos-staging.evergreenwellnessmktg.com

# ===== OPTIONAL — AI COACH =====

# OpenAI-compatible LLM endpoint for /coach. Defaults to localhost Ollama.
# Examples:
#   http://192.168.4.200:11434/v1   (Ollama on M90t)
#   http://192.168.4.180:11434/v1   (Ollama on Framestation)
#   http://localhost:11434/v1       (Ollama on M4)
# LIFEOS_LLM_BASE_URL=http://192.168.4.200:11434/v1
# LIFEOS_LLM_API_KEY=ollama
# LIFEOS_LLM_MODEL=qwen2.5:32b
