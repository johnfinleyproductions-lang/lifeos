# Copy to .env.local and fill in. Local file is gitignored.

# Postgres on M90t — use the EXACT same string as ~/evergreen-core/.env.local
DATABASE_URL=

# Better Auth secret — use the EXACT same string as EC's BETTER_AUTH_SECRET
# (this is what enables shared sessions across the two apps)
BETTER_AUTH_SECRET=

# Local dev: http://localhost:3001
# Production: https://lifeos.evergreenwellnessmktg.com
NEXT_PUBLIC_APP_URL=http://localhost:3001

# EC's URL — used as a trusted origin for SSO
NEXT_PUBLIC_EC_URL=https://app.evergreenwellnessmktg.com
